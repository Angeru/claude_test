<div class="rounded-lg border overflow-hidden transition-all duration-300 <%= unit.defeated? ? 'border-red-900/40 opacity-60' : 'border-amber-900/30 hover:border-amber-700/50' %> bg-gradient-to-b from-stone-900/80 to-stone-950/80">
  <!-- Unit Header -->
  <div class="px-4 py-3 border-b <%= unit.defeated? ? 'border-red-900/30 bg-red-950/30' : 'border-stone-800/50 bg-stone-900/50' %>">
    <div class="flex justify-between items-center">
      <div>
        <h3 class="text-amber-100" style="font-family: 'Cinzel', serif; font-size: 0.95rem;"><%= unit.warband_member.name %></h3>
        <span class="inline-block text-xs px-2 py-0.5 rounded mt-1 <%= unit.warband_member.hero? ? 'text-amber-400/80 border border-amber-900/40 bg-amber-900/20' : 'text-stone-400/80 border border-stone-700/40 bg-stone-800/30' %>" style="font-family: 'Cinzel', serif; font-size: 0.55rem; letter-spacing: 0.1em;">
          <%= unit.warband_member.display_type %>
        </span>
      </div>
      <% if unit.defeated? %>
        <span class="px-3 py-1 text-xs text-red-400 border border-red-800/40 rounded bg-red-900/20 font-bold" style="font-family: 'Cinzel', serif; font-size: 0.6rem; letter-spacing: 0.1em;">
          DERROTADO
        </span>
      <% end %>
    </div>
  </div>

  <!-- Wounds Tracker -->
  <div class="px-4 py-4">
    <div class="text-center mb-4">
      <p class="text-xs text-amber-200/60 tracking-wider uppercase mb-2" style="font-family: 'Cinzel', serif; font-size: 0.6rem;">Heridas</p>
      <div class="flex items-center justify-center gap-4">
        <% if @battle_roster.active? %>
          <%= button_to wound_campaign_campaign_round_matchup_battle_roster_battle_roster_unit_path(
              @campaign, @round, @matchup, @battle_roster, unit),
              method: :patch,
              class: "inline-flex items-center justify-center w-10 h-10 rounded-full #{unit.defeated? ? 'bg-stone-800/50 text-stone-600 cursor-not-allowed' : 'bg-red-900/30 text-red-400 hover:bg-red-900/50 border border-red-800/40'} text-xl font-bold transition-colors",
              disabled: unit.defeated? do %>
            -
          <% end %>
        <% end %>

        <div class="text-center">
          <span class="text-4xl font-bold <%= unit.defeated? ? 'text-red-500' : (unit.current_wounds <= 1 && unit.max_wounds > 1 ? 'text-orange-400' : 'text-amber-100') %>" style="font-family: 'Cinzel', serif;">
            <%= unit.current_wounds %>
          </span>
          <span class="text-xl text-stone-600" style="font-family: 'Cinzel', serif;"> / <%= unit.max_wounds %></span>
        </div>

        <% if @battle_roster.active? %>
          <%= button_to heal_campaign_campaign_round_matchup_battle_roster_battle_roster_unit_path(
              @campaign, @round, @matchup, @battle_roster, unit),
              method: :patch,
              class: "inline-flex items-center justify-center w-10 h-10 rounded-full #{unit.current_wounds >= unit.max_wounds ? 'bg-stone-800/50 text-stone-600 cursor-not-allowed' : 'bg-emerald-900/30 text-emerald-400 hover:bg-emerald-900/50 border border-emerald-800/40'} text-xl font-bold transition-colors",
              disabled: unit.current_wounds >= unit.max_wounds do %>
            +
          <% end %>
        <% end %>
      </div>

      <!-- Wound Pips -->
      <div class="flex justify-center gap-1 mt-3">
        <% unit.max_wounds.times do |i| %>
          <div class="w-4 h-4 rounded-full border-2 <%= i < unit.current_wounds ? 'bg-red-600 border-red-500' : 'bg-stone-800 border-stone-700' %>"></div>
        <% end %>
      </div>
    </div>

    <!-- Might / Will / Fate -->
    <% if unit.has_spendable? %>
      <div class="mt-4 pt-4 border-t border-stone-800/50 space-y-2">
        <% [["might", "M", "text-yellow-400", "border-yellow-800/40", "bg-yellow-900/30", "hover:bg-yellow-900/50"],
            ["will",  "W", "text-blue-400",   "border-blue-800/40",   "bg-blue-900/30",   "hover:bg-blue-900/50"],
            ["fate",  "F", "text-purple-400", "border-purple-800/40", "bg-purple-900/30", "hover:bg-purple-900/50"]].each do |attr, label, color, border, bg, hover| %>
          <% max = unit.warband_member.send(attr) %>
          <% next if max == 0 %>
          <% current = unit.send(:"current_#{attr}") %>
          <div class="flex items-center gap-2">
            <span class="w-4 text-center text-xs font-bold <%= color %>" style="font-family: 'Cinzel', serif; font-size: 0.6rem;"><%= label %></span>
            <% if @battle_roster.active? %>
              <%= button_to spend_campaign_campaign_round_matchup_battle_roster_battle_roster_unit_path(
                  @campaign, @round, @matchup, @battle_roster, unit),
                  params: { attribute: attr },
                  method: :patch,
                  class: "inline-flex items-center justify-center w-6 h-6 rounded-full text-sm font-bold transition-colors #{current <= 0 ? 'bg-stone-800/50 text-stone-600 cursor-not-allowed' : "#{bg} #{color} #{hover} #{border} border"}",
                  disabled: current <= 0 do %>
                -
              <% end %>
            <% end %>
            <div class="flex gap-1">
              <% max.times do |i| %>
                <div class="w-3 h-3 rounded-full border <%= i < current ? "#{bg} #{border} border" : 'bg-stone-800 border-stone-700' %>"></div>
              <% end %>
            </div>
            <span class="text-xs <%= color %>" style="font-family: 'Crimson Text', serif;"><%= current %>/<%= max %></span>
            <% if @battle_roster.active? %>
              <%= button_to restore_campaign_campaign_round_matchup_battle_roster_battle_roster_unit_path(
                  @campaign, @round, @matchup, @battle_roster, unit),
                  params: { attribute: attr },
                  method: :patch,
                  class: "inline-flex items-center justify-center w-6 h-6 rounded-full text-sm font-bold transition-colors #{current >= max ? 'bg-stone-800/50 text-stone-600 cursor-not-allowed' : "#{bg} #{color} #{hover} #{border} border"}",
                  disabled: current >= max do %>
                +
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Battle Ticks -->
    <div class="mt-4 pt-4 border-t border-stone-800/50">
      <p class="text-xs text-amber-200/60 tracking-wider uppercase mb-2 text-center" style="font-family: 'Cinzel', serif; font-size: 0.6rem;">Logros</p>
      <div class="space-y-1">
        <% [
          ["wounded_enemy",  "Hirió a un enemigo"],
          ["fate_protected", "Evitó herida con Fate"],
          ["courage_broken", "Superó coraje estando Roto"]
        ].each do |tick, label| %>
          <% checked = unit.public_send(tick) %>
          <% if @matchup.completed? %>
            <div class="w-full flex items-center gap-2 px-2 py-1.5 rounded border <%= checked ? 'bg-amber-900/30 border-amber-700/50 text-amber-300' : 'bg-stone-900/50 border-stone-700/30 text-stone-500' %>">
              <span class="flex-shrink-0 w-4 h-4 rounded border-2 flex items-center justify-center <%= checked ? 'border-amber-500 bg-amber-600/40' : 'border-stone-600' %>">
                <% if checked %>
                  <svg class="w-2.5 h-2.5 text-amber-300" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="2,6 5,9 10,3"/>
                  </svg>
                <% end %>
              </span>
              <span style="font-family: 'Crimson Text', serif; font-size: 0.85rem;"><%= label %></span>
            </div>
          <% else %>
            <%= button_to toggle_tick_campaign_campaign_round_matchup_battle_roster_battle_roster_unit_path(
                @campaign, @round, @matchup, @battle_roster, unit),
                params: { tick: tick },
                method: :patch,
                class: "w-full flex items-center gap-2 px-2 py-1.5 rounded border transition-colors #{checked ? 'bg-amber-900/30 border-amber-700/50 text-amber-300' : 'bg-stone-900/50 border-stone-700/30 text-stone-500 hover:border-stone-600/50 hover:text-stone-400'}" do %>
              <span class="flex-shrink-0 w-4 h-4 rounded border-2 flex items-center justify-center <%= checked ? 'border-amber-500 bg-amber-600/40' : 'border-stone-600' %>">
                <% if checked %>
                  <svg class="w-2.5 h-2.5 text-amber-300" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="2,6 5,9 10,3"/>
                  </svg>
                <% end %>
              </span>
              <span style="font-family: 'Crimson Text', serif; font-size: 0.85rem;"><%= label %></span>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>

    <% if @matchup.completed? %>
      <!-- Resultado Final (solo lectura) -->
      <div class="mt-4 pt-4 border-t border-stone-800/50">
        <p class="text-xs text-amber-200/60 tracking-wider uppercase mb-2 text-center" style="font-family: 'Cinzel', serif; font-size: 0.6rem;">Fin de Batalla</p>
        <div class="space-y-1">
          <div class="w-full flex items-center gap-2 px-2 py-1.5 rounded border <%= unit.on_objective ? 'bg-amber-900/30 border-amber-700/50 text-amber-300' : 'bg-stone-900/50 border-stone-700/30 text-stone-500' %>">
            <span class="flex-shrink-0 w-4 h-4 rounded border-2 flex items-center justify-center <%= unit.on_objective ? 'border-amber-500 bg-amber-600/40' : 'border-stone-600' %>">
              <% if unit.on_objective %>
                <svg class="w-2.5 h-2.5 text-amber-300" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="2,6 5,9 10,3"/>
                </svg>
              <% end %>
            </span>
            <span style="font-family: 'Crimson Text', serif; font-size: 0.85rem;">En un objetivo</span>
          </div>
          <div class="w-full flex items-center gap-2 px-2 py-1.5 rounded border <%= unit.mvp ? 'bg-yellow-900/40 border-yellow-600/60 text-yellow-300' : 'bg-stone-900/50 border-stone-700/30 text-stone-500' %>">
            <span class="flex-shrink-0 w-4 h-4 flex items-center justify-center">
              <svg viewBox="0 0 24 24" class="w-4 h-4 <%= unit.mvp ? 'text-yellow-400' : 'text-stone-600' %>" fill="currentColor">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            </span>
            <span style="font-family: 'Crimson Text', serif; font-size: 0.85rem;">MVP</span>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Bajas -->
    <div class="mt-4 pt-4 border-t border-stone-800/50">
      <p class="text-xs text-amber-200/60 tracking-wider uppercase mb-2 text-center" style="font-family: 'Cinzel', serif; font-size: 0.6rem;">Heroes o monstruos eliminados</p>
      <div class="flex items-center justify-center gap-3">
        <% if @battle_roster.active? %>
          <%= button_to unkill_campaign_campaign_round_matchup_battle_roster_battle_roster_unit_path(
              @campaign, @round, @matchup, @battle_roster, unit),
              method: :patch,
              class: "inline-flex items-center justify-center w-6 h-6 rounded-full text-sm font-bold transition-colors #{unit.kills <= 0 ? 'bg-stone-800/50 text-stone-600 cursor-not-allowed' : 'bg-red-900/30 text-red-400 hover:bg-red-900/50 border border-red-800/40'}",
              disabled: unit.kills <= 0 do %>
            −
          <% end %>
        <% end %>
        <span class="text-red-400 font-bold" style="font-family: 'Cinzel', serif; font-size: 1.1rem;"><%= unit.kills %></span>
        <% if @battle_roster.active? %>
          <%= button_to kill_campaign_campaign_round_matchup_battle_roster_battle_roster_unit_path(
              @campaign, @round, @matchup, @battle_roster, unit),
              method: :patch,
              class: "inline-flex items-center justify-center w-6 h-6 rounded-full text-sm font-bold transition-colors bg-red-900/30 text-red-400 hover:bg-red-900/50 border border-red-800/40" do %>
            +
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Stats Summary -->
    <div class="grid grid-cols-3 gap-1 text-xs mt-3 pt-3 border-t border-stone-800/50">
      <div class="bg-stone-900/60 p-1.5 rounded text-center border border-stone-800/30">
        <span class="font-semibold text-amber-200/50 block" style="font-family: 'Cinzel', serif; font-size: 0.5rem;">Mov</span>
        <span class="text-stone-300" style="font-family: 'Crimson Text', serif;"><%= unit.warband_member.movimiento %>"</span>
      </div>
      <div class="bg-stone-900/60 p-1.5 rounded text-center border border-stone-800/30">
        <span class="font-semibold text-amber-200/50 block" style="font-family: 'Cinzel', serif; font-size: 0.5rem;">L</span>
        <span class="text-stone-300" style="font-family: 'Crimson Text', serif;"><%= unit.warband_member.lucha %>+</span>
      </div>
      <div class="bg-stone-900/60 p-1.5 rounded text-center border border-stone-800/30">
        <span class="font-semibold text-amber-200/50 block" style="font-family: 'Cinzel', serif; font-size: 0.5rem;">F</span>
        <span class="text-stone-300" style="font-family: 'Crimson Text', serif;"><%= unit.warband_member.fuerza %></span>
      </div>
      <div class="bg-stone-900/60 p-1.5 rounded text-center border border-stone-800/30">
        <span class="font-semibold text-amber-200/50 block" style="font-family: 'Cinzel', serif; font-size: 0.5rem;">D</span>
        <span class="text-stone-300" style="font-family: 'Crimson Text', serif;"><%= unit.warband_member.defensa %></span>
      </div>
      <div class="bg-stone-900/60 p-1.5 rounded text-center border border-stone-800/30">
        <span class="font-semibold text-amber-200/50 block" style="font-family: 'Cinzel', serif; font-size: 0.5rem;">A</span>
        <span class="text-stone-300" style="font-family: 'Crimson Text', serif;"><%= unit.warband_member.ataques %></span>
      </div>
      <div class="bg-stone-900/60 p-1.5 rounded text-center border border-stone-800/30">
        <span class="font-semibold text-amber-200/50 block" style="font-family: 'Cinzel', serif; font-size: 0.5rem;">C</span>
        <span class="text-stone-300" style="font-family: 'Crimson Text', serif;"><%= unit.warband_member.coraje %></span>
      </div>
    </div>
  </div>
</div>
