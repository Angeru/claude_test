<% content_for(:body_class) { "bg-stone-950" } %>
<% content_for(:raw_content) { true } %>

<%= render layout: "shared/dark_layout", locals: { max_width: "max-w-4xl" } do %>
  <%= link_to warband_warband_members_path(@warband), class: "inline-flex items-center gap-2 text-amber-400 hover:text-amber-300 transition-colors mb-6", style: "font-family: 'Cinzel', serif; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase;" do %>
    <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    Miembros
  <% end %>

  <div class="flex items-center gap-4 mb-3">
    <div class="h-px w-8 bg-gradient-to-r from-transparent to-amber-700/60"></div>
    <svg viewBox="0 0 24 24" class="w-4 h-4 text-amber-600/60" fill="currentColor">
      <polygon points="12,2 15,9 22,9 16,14 18,21 12,17 6,21 8,14 2,9 9,9"/>
    </svg>
    <div class="h-px w-8 bg-gradient-to-l from-transparent to-amber-700/60"></div>
  </div>
  <h1 class="text-amber-100 tracking-[0.1em] uppercase mb-6" style="font-family: 'Cinzel', serif; font-size: 1.6rem; font-weight: 700;">
    Anadir Miembro a <%= @warband.name %>
  </h1>

  <% if @profiles.any? %>
    <div class="rounded-lg border border-stone-700/40 bg-stone-900/40 p-5 mb-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-px w-6 bg-stone-700/60"></div>
        <h3 class="text-stone-300/80 tracking-wider uppercase" style="font-family: 'Cinzel', serif; font-size: 0.8rem;">Usar un Perfil como Base</h3>
        <div class="h-px flex-1 bg-stone-700/60"></div>
      </div>
      <p class="text-stone-500 text-sm mb-4" style="font-family: 'Crimson Text', serif;">
        Selecciona un perfil guardado para pre-rellenar las estadísticas del nuevo miembro.
      </p>
      <%= form_with url: new_warband_warband_member_path(@warband), method: :get, class: "flex items-end gap-3" do |f| %>
        <div class="flex-1">
          <%= f.select :profile_id,
              options_for_select(
                @profiles.map { |p| ["#{p.name} (#{p.display_type})", p.id] },
                params[:profile_id]
              ),
              { include_blank: "-- Seleccionar perfil --" },
              class: "w-full py-2.5 px-4 bg-stone-900/80 border border-stone-700/50 rounded text-amber-100 focus:outline-none focus:border-amber-700/60 focus:ring-1 focus:ring-amber-700/30 transition-colors",
              style: "font-family: 'Crimson Text', serif;" %>
        </div>
        <%= f.submit "Aplicar Perfil",
            class: "px-5 py-2.5 bg-stone-800 text-stone-300 rounded border border-stone-700/50 hover:bg-stone-700 hover:text-amber-200 transition-all cursor-pointer whitespace-nowrap",
            style: "font-family: 'Cinzel', serif; letter-spacing: 0.05em; text-transform: uppercase; font-size: 0.7rem;" %>
        <% if params[:profile_id].present? %>
          <%= link_to "Limpiar", new_warband_warband_member_path(@warband),
              class: "px-4 py-2.5 text-stone-500 hover:text-stone-300 transition-colors",
              style: "font-family: 'Cinzel', serif; font-size: 0.7rem;" %>
        <% end %>
      <% end %>
      <div class="mt-3 flex items-center justify-end">
        <%= link_to "Gestionar perfiles →", member_profiles_path,
            class: "text-xs text-stone-600 hover:text-amber-400/60 transition-colors",
            style: "font-family: 'Cinzel', serif;" %>
      </div>
    </div>
  <% else %>
    <div class="rounded-lg border border-stone-800/30 bg-stone-900/20 px-5 py-4 mb-8 flex items-center justify-between">
      <p class="text-stone-500 text-sm" style="font-family: 'Crimson Text', serif;">
        No tienes perfiles guardados. Puedes crear perfiles reutilizables para pre-rellenar estadísticas.
      </p>
      <%= link_to "Crear perfil →", new_member_profile_path,
          class: "text-xs text-amber-600/60 hover:text-amber-400/80 transition-colors whitespace-nowrap ml-4",
          style: "font-family: 'Cinzel', serif;" %>
    </div>
  <% end %>

  <%= render 'form', warband: @warband, member: @member %>
<% end %>
