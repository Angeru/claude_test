<% content_for(:body_class) { "bg-stone-950" } %>
<% content_for(:raw_content) { true } %>

<%= render layout: "shared/dark_layout" do %>
  <%= link_to warband_warband_member_warband_equipments_path(@warband_member.warband, @warband_member), class: "inline-flex items-center gap-2 text-amber-400 hover:text-amber-300 transition-colors mb-6", style: "font-family: 'Cinzel', serif; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase;" do %>
    <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    Equipo
  <% end %>

  <div class="flex items-center gap-4 mb-3">
    <div class="h-px w-8 bg-gradient-to-r from-transparent to-amber-700/60"></div>
    <svg viewBox="0 0 24 24" class="w-4 h-4 text-amber-600/60" fill="currentColor">
      <polygon points="12,2 15,9 22,9 16,14 18,21 12,17 6,21 8,14 2,9 9,9"/>
    </svg>
    <div class="h-px w-8 bg-gradient-to-l from-transparent to-amber-700/60"></div>
  </div>
  <div class="flex items-start justify-between mb-2">
    <h1 class="text-amber-100 tracking-[0.1em] uppercase" style="font-family: 'Cinzel', serif; font-size: 1.6rem; font-weight: 700;">
      Editar Equipo
    </h1>
    <%= button_to save_as_profile_warband_warband_member_warband_equipment_path(@warband_member.warband, @warband_member, @equipment),
        method: :post,
        class: "inline-flex items-center gap-2 px-3 py-1.5 bg-stone-800/60 border border-amber-900/40 text-amber-400/80 rounded hover:bg-amber-950/40 hover:text-amber-300 hover:border-amber-700/50 transition-all",
        style: "font-family: 'Cinzel', serif; font-size: 0.65rem; letter-spacing: 0.08em; text-transform: uppercase;",
        data: { turbo_confirm: "¿Guardar \"#{@equipment.name}\" como perfil en el catálogo?" } do %>
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 21H7a2 2 0 01-2-2V5a2 2 0 012-2h7l5 5v11a2 2 0 01-2 2z"/>
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 21v-8H7v8M7 3v5h8"/>
      </svg>
      Guardar como Perfil
    <% end %>
  </div>
  <p class="text-stone-400 mb-8" style="font-family: 'Crimson Text', serif;">Editando <%= @equipment.name %> de <%= @warband_member.name %></p>

  <%= render "form", equipment: @equipment %>
<% end %>
