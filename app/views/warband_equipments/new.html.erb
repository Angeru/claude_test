<% content_for(:body_class) { "bg-stone-950" } %>
<% content_for(:raw_content) { true } %>

<%= render layout: "shared/dark_layout" do %>
  <%= link_to warband_warband_member_warband_equipments_path(@warband_member.warband, @warband_member), class: "inline-flex items-center gap-2 text-amber-400 hover:text-amber-300 transition-colors mb-6", style: "font-family: 'Cinzel', serif; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase;" do %>
    <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    Equipo
  <% end %>

  <div class="flex items-center gap-4 mb-3">
    <div class="h-px w-8 bg-gradient-to-r from-transparent to-amber-700/60"></div>
    <svg viewBox="0 0 24 24" class="w-4 h-4 text-amber-600/60" fill="currentColor">
      <polygon points="12,2 15,9 22,9 16,14 18,21 12,17 6,21 8,14 2,9 9,9"/>
    </svg>
    <div class="h-px w-8 bg-gradient-to-l from-transparent to-amber-700/60"></div>
  </div>
  <h1 class="text-amber-100 tracking-[0.1em] uppercase mb-2" style="font-family: 'Cinzel', serif; font-size: 1.6rem; font-weight: 700;">
    Anadir Equipo
  </h1>
  <p class="text-stone-400 mb-8" style="font-family: 'Crimson Text', serif;">Anadiendo equipo a <%= @warband_member.name %></p>

  <% if @catalog_equipments.any? %>
    <div class="rounded-lg border border-amber-900/30 bg-amber-950/20 p-5 mb-6">
      <div class="flex items-center gap-3 mb-4">
        <svg class="w-4 h-4 text-amber-400/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <h3 class="text-amber-200/80 tracking-wider uppercase" style="font-family: 'Cinzel', serif; font-size: 0.75rem;">Cargar desde el Catalogo</h3>
      </div>
      <%= form_with url: new_warband_warband_member_warband_equipment_path(@warband_member.warband, @warband_member), method: :get, local: true, class: "flex gap-3 items-end" do |f| %>
        <div class="flex-1">
          <%= f.label :from_equipment_id, "Selecciona un equipo del catalogo", class: "block text-amber-200/60 text-xs tracking-widest uppercase mb-2", style: "font-family: 'Cinzel', serif; font-size: 0.6rem;" %>
          <%= f.select :from_equipment_id,
              options_for_select(@catalog_equipments.map { |e| ["#{e.name} (#{e.display_type} · #{e.cost}pts)", e.id] }, params[:from_equipment_id]),
              { include_blank: "— Elige del catalogo —" },
              class: "w-full py-2.5 px-4 bg-stone-900/80 border border-amber-900/40 rounded text-amber-100 focus:outline-none focus:border-amber-700/60 focus:ring-1 focus:ring-amber-700/30 transition-colors", style: "font-family: 'Crimson Text', serif;" %>
        </div>
        <%= f.submit "Cargar",
            class: "px-4 py-2.5 bg-amber-900/40 border border-amber-700/40 text-amber-300 rounded hover:bg-amber-800/40 hover:text-amber-200 transition-all cursor-pointer whitespace-nowrap",
            style: "font-family: 'Cinzel', serif; font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase;" %>
      <% end %>
      <% if params[:from_equipment_id].present? %>
        <p class="mt-3 text-amber-300/60 text-xs" style="font-family: 'Crimson Text', serif;">Formulario pre-rellenado desde el catalogo. Puedes modificar los valores antes de guardar.</p>
      <% end %>
    </div>
  <% end %>

  <%= render "form", equipment: @equipment %>
<% end %>
